---
import Layout from './Layout.astro';
import '../styles/page-main.css';

interface Props {
	frontmatter: {
		title: string;
		description?: string;
	};
}

const { frontmatter } = Astro.props;
---

<Layout
	title={frontmatter.title}
	description={frontmatter.description ?? `${frontmatter.title} · kspice.dev`}
>
	<main class="main tutorial-md">
		<slot />
	</main>
</Layout>

<style>
	.tutorial-md :global(h1) {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem;
		color: var(--purple-dark);
	}

	.tutorial-md :global(h2) {
		font-size: 1.125rem;
		font-weight: 600;
		margin: 2rem 0 0.5rem;
		color: var(--teal-dark);
	}

	.tutorial-md :global(h3) {
		font-size: 1rem;
		font-weight: 600;
		margin: 1.25rem 0 0.4rem;
		color: var(--ink);
	}

	.tutorial-md :global(p) {
		margin: 0 0 1rem;
		color: var(--muted);
	}

	.tutorial-md :global(ul),
	.tutorial-md :global(ol) {
		margin: 0 0 1rem;
		padding-left: 1.35rem;
		color: var(--muted);
	}

	.tutorial-md :global(li) {
		margin: 0.25rem 0;
	}

	.tutorial-md :global(a) {
		color: var(--teal-dark);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.tutorial-md :global(a:hover) {
		color: var(--purple-dark);
	}

	.tutorial-md :global(code) {
		font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
		font-size: 0.9em;
		background: var(--purple-soft);
		color: var(--ink);
		padding: 0.15em 0.4em;
		border-radius: 4px;
		border: 1px solid var(--border);
	}

	.tutorial-md :global(pre) {
		margin: 0 0 1rem;
		padding: 1rem 1.1rem;
		overflow-x: auto;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: var(--bg-elevated);
	}

	.tutorial-md :global(pre code) {
		padding: 0;
		border: none;
		background: transparent;
		font-size: 0.875rem;
		line-height: 1.45;
	}

	.tutorial-md :global(blockquote) {
		margin: 0 0 1rem;
		padding: 0.5rem 0 0.5rem 1rem;
		border-left: 3px solid var(--teal);
		color: var(--muted);
	}

	.tutorial-md :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 1rem 0;
		border-radius: 8px;
		border: 1px solid var(--border);
	}

	.tutorial-md :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2rem 0;
	}
</style>
