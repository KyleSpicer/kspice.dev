---
import '../styles/global.css';
import SocialFooter from '../components/SocialFooter.astro';
import { sitePath } from '../utils/sitePath';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'kspice.dev',
	description = 'Programming tutorials and more.',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

function navIsActive(href: string): boolean {
	if (href.includes('#contact')) return false;
	const h = href.replace(/\/$/, '') || '/';
	if (pathname === h) return true;
	return pathname.startsWith(h + '/');
}

/** Header brand mark (`public/images/logo/`). Logo-04 PNG matches the transparent wordmark style. */
const brandLogoSrc = sitePath('/images/logo/KSPICE.DEV-Logo-04.png');

/** Tab / bookmark icon (square mark, same family as home hero). */
const faviconSvgSrc = sitePath('/images/logo/KSPICE.DEV-Logo-01.svg');
const faviconPngSrc = sitePath('/images/logo/KSPICE.DEV-Logo-01.png');

const nav = [
	{ href: sitePath('/'), label: 'Home' },
	{ href: sitePath('/programming'), label: 'Programming' },
	{ href: sitePath('/woodworking'), label: 'Woodworking' },
	{ href: sitePath('/recommendations'), label: 'Book Recommendations' },
	{ href: sitePath('/resume'), label: 'Resume' },
	{ href: `${sitePath('/')}#contact`, label: 'Contact' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="color-scheme" content="dark light" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={faviconSvgSrc} />
		<link rel="icon" type="image/png" sizes="32x32" href={faviconPngSrc} />
		<link rel="apple-touch-icon" href={faviconPngSrc} />
		<meta name="generator" content={Astro.generator} />
		<title>{title === 'kspice.dev' ? title : `${title} · kspice.dev`}</title>
		<script is:inline>
			(function () {
				var k = 'kspice-theme';
				var t = localStorage.getItem(k);
				if (t !== 'light' && t !== 'dark') t = 'dark';
				document.documentElement.setAttribute('data-theme', t);
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={sitePath('/')}>
				<img
					class="brand__logo"
					src={brandLogoSrc}
					alt="kspice.dev"
					width="1000"
					height="1000"
					loading="eager"
					decoding="async"
				/>
			</a>
			<div class="header-tools">
				<button
					type="button"
					class="theme-toggle theme-toggle--dark"
					id="theme-toggle"
					aria-label="Switch to light mode"
				>
					<span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">☀</span>
					<span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">☾</span>
				</button>
				<button
					type="button"
					class="menu-toggle"
					id="menu-toggle"
					aria-expanded="false"
					aria-controls="site-nav"
					aria-label="Open menu"
				>
					<span class="menu-toggle__bars" aria-hidden="true">
						<span class="menu-toggle__bar"></span>
						<span class="menu-toggle__bar"></span>
						<span class="menu-toggle__bar"></span>
					</span>
				</button>
			</div>
			<button
				type="button"
				class="nav-backdrop"
				id="nav-backdrop"
				tabindex="-1"
				aria-hidden="true"
			>
			</button>
			<nav class="nav" id="site-nav" aria-label="Main">
				<ul>
					{
						nav.map(({ href, label }) => {
							const active = navIsActive(href);
							return (
								<li>
									<a
										href={href}
										class:list={['nav-link', { active }]}
										aria-current={active ? 'page' : undefined}
									>
										{label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</header>
		<slot />
		<SocialFooter />
		<script is:inline>
			(function () {
				var themeKey = 'kspice-theme';
				var themeBtn = document.getElementById('theme-toggle');
				if (themeBtn) {
					function themeLabel(t) {
						return t === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
					}
					function syncTheme(t) {
						themeBtn.setAttribute('aria-label', themeLabel(t));
						themeBtn.classList.toggle('theme-toggle--dark', t === 'dark');
						themeBtn.classList.toggle('theme-toggle--light', t === 'light');
					}
					syncTheme(document.documentElement.getAttribute('data-theme') || 'dark');
					themeBtn.addEventListener('click', function () {
						var cur = document.documentElement.getAttribute('data-theme') || 'dark';
						var next = cur === 'dark' ? 'light' : 'dark';
						document.documentElement.setAttribute('data-theme', next);
						localStorage.setItem(themeKey, next);
						syncTheme(next);
					});
				}

				var header = document.querySelector('.site-header');
				var menuBtn = document.getElementById('menu-toggle');
				var backdrop = document.getElementById('nav-backdrop');
				var mainNav = document.getElementById('site-nav');
				if (!header || !menuBtn || !mainNav) return;

				function menuOpen() {
					return header.classList.contains('is-menu-open');
				}
				function syncAria() {
					if (menuOpen()) mainNav.removeAttribute('aria-hidden');
					else mainNav.setAttribute('aria-hidden', 'true');
				}
				function closeMenu(refocus) {
					var was = menuOpen();
					header.classList.remove('is-menu-open');
					menuBtn.setAttribute('aria-expanded', 'false');
					menuBtn.setAttribute('aria-label', 'Open menu');
					document.body.style.overflow = '';
					syncAria();
					if (refocus && was) menuBtn.focus();
				}
				function openMenu() {
					header.classList.add('is-menu-open');
					menuBtn.setAttribute('aria-expanded', 'true');
					menuBtn.setAttribute('aria-label', 'Close menu');
					document.body.style.overflow = 'hidden';
					syncAria();
					var first = mainNav.querySelector('a');
					if (first) requestAnimationFrame(function () { first.focus(); });
				}

				menuBtn.addEventListener('click', function () {
					menuOpen() ? closeMenu(true) : openMenu();
				});
				if (backdrop) backdrop.addEventListener('click', function () { closeMenu(true); });
				mainNav.addEventListener('click', function (ev) {
					if (ev.target.closest('a')) closeMenu(false);
				});
				document.addEventListener('keydown', function (ev) {
					if (ev.key === 'Escape' && menuOpen()) closeMenu(true);
				});
				var resizeCloseTimer;
				window.addEventListener(
					'resize',
					function () {
						clearTimeout(resizeCloseTimer);
						resizeCloseTimer = setTimeout(function () {
							closeMenu(false);
							syncAria();
						}, 150);
					},
					{ passive: true },
				);
				syncAria();
			})();
		</script>
	</body>
</html>

<style>
	.site-header {
		position: relative;
		z-index: 50;
		display: grid;
		align-items: center;
		column-gap: 1rem;
		padding: 0.65rem max(1rem, env(safe-area-inset-right)) 0.65rem max(1rem, env(safe-area-inset-left));
		border-bottom: 2px solid var(--border);
		background: var(--bg-elevated);
		grid-template-columns: minmax(0, 1fr) auto;
		grid-template-rows: auto;
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease;
	}

	.brand {
		grid-column: 1;
		grid-row: 1;
		display: flex;
		align-items: center;
		align-self: center;
		text-decoration: none;
		min-width: 0;
		outline-offset: 3px;
	}

	.brand:hover .brand__logo {
		opacity: 0.9;
	}

	.brand:focus-visible {
		outline: 2px solid var(--purple);
	}

	.brand__logo {
		/* flex-shrink: 0 avoids grid squeezing the image. Tweak height / max-width to taste. */
		height: 2.25rem;
		width: auto;
		max-width: min(8.75rem, 100%);
		display: block;
		flex-shrink: 0;
		object-fit: contain;
		object-position: left center;
		transition:
			opacity 0.15s ease,
			filter 0.2s ease;
	}

	/* Logo-04 is dark on transparent; invert on dark header for contrast */
	[data-theme='dark'] .brand__logo {
		filter: brightness(0) invert(1);
	}

	.header-tools {
		grid-column: 2;
		grid-row: 1;
		display: flex;
		align-items: center;
		justify-self: end;
		gap: 0.45rem;
	}

	.theme-toggle,
	.menu-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 2px solid var(--border);
		border-radius: 10px;
		background: var(--bg);
		color: var(--ink);
		cursor: pointer;
		flex-shrink: 0;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.theme-toggle {
		font-size: 1.125rem;
		line-height: 1;
	}

	.menu-toggle {
		-webkit-tap-highlight-color: transparent;
		touch-action: manipulation;
	}

	.theme-toggle:hover,
	.menu-toggle:hover {
		border-color: var(--teal);
		color: var(--teal-dark);
	}

	.theme-toggle:focus-visible,
	.menu-toggle:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: 2px;
	}

	.menu-toggle__bars {
		display: flex;
		flex-direction: column;
		gap: 5px;
		width: 1.125rem;
	}

	.menu-toggle__bar {
		display: block;
		height: 2px;
		width: 100%;
		background: currentColor;
		border-radius: 1px;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
		transform-origin: center;
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.nav-backdrop {
		position: fixed;
		inset: 0;
		z-index: 1000;
		margin: 0;
		padding: 0;
		border: none;
		background: color-mix(in srgb, var(--ink) 45%, transparent);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.2s ease,
			visibility 0.2s ease;
	}

	.site-header.is-menu-open .nav-backdrop {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.nav {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		z-index: 1001;
		width: min(19.5rem, 90vw);
		margin: 0;
		padding: max(4.25rem, calc(2.75rem + 1.35rem + env(safe-area-inset-top))) max(1rem, env(safe-area-inset-right)) 1.5rem
			max(1.25rem, env(safe-area-inset-left));
		background: var(--bg-elevated);
		border-left: 1px solid var(--border);
		box-shadow: -16px 0 48px color-mix(in srgb, var(--ink) 14%, transparent);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		transform: translateX(100%);
		visibility: hidden;
		transition:
			transform 0.25s ease,
			visibility 0.25s ease;
	}

	.site-header.is-menu-open .nav {
		transform: translateX(0);
		visibility: visible;
	}

	.nav ul {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.35rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-link {
		display: block;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.25;
		padding: 0.75rem 0.85rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: var(--bg);
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background-color 0.15s ease;
	}

	.nav-link:hover {
		color: var(--teal-dark);
		border-color: var(--teal-soft);
	}

	.nav-link.active {
		color: var(--purple-dark);
		border-color: var(--purple);
		background: color-mix(in srgb, var(--purple) 10%, var(--bg));
	}

	.theme-toggle__icon {
		display: none;
	}

	.theme-toggle--dark .theme-toggle__icon--sun {
		display: block;
	}

	.theme-toggle--light .theme-toggle__icon--moon {
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.nav,
		.nav-backdrop,
		.menu-toggle__bar {
			transition: none !important;
		}
	}

	@media (min-width: 52rem) {
		.site-header {
			padding: 1rem max(1.5rem, env(safe-area-inset-right)) 1rem max(1.5rem, env(safe-area-inset-left));
		}
	}

</style>
