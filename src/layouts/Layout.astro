---
import '../styles/global.css';
import SocialFooter from '../components/SocialFooter.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'kspice.dev',
	description = 'Programming, woodworking, and more.',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/programming', label: 'Programming Tutorials' },
	{ href: '/projects', label: 'Documented Projects' },
	{ href: '/woodworking', label: 'Woodworking' },
	{ href: '/resume', label: 'Resume' },
	{ href: '/#contact', label: 'Contact' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="color-scheme" content="dark light" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title === 'kspice.dev' ? title : `${title} · kspice.dev`}</title>
		<script is:inline>
			(function () {
				var k = 'kspice-theme';
				var t = localStorage.getItem(k);
				if (t !== 'light' && t !== 'dark') t = 'dark';
				document.documentElement.setAttribute('data-theme', t);
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">kspice.dev</a>
			<div class="header-tools">
				<button
					type="button"
					class="theme-toggle theme-toggle--dark"
					id="theme-toggle"
					aria-label="Switch to light mode"
				>
					<span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">☀</span>
					<span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">☾</span>
				</button>
				<button
					type="button"
					class="menu-toggle"
					id="menu-toggle"
					aria-expanded="false"
					aria-controls="site-nav"
					aria-label="Open menu"
				>
					<span class="menu-toggle__bars" aria-hidden="true">
						<span class="menu-toggle__bar"></span>
						<span class="menu-toggle__bar"></span>
						<span class="menu-toggle__bar"></span>
					</span>
				</button>
			</div>
			<button
				type="button"
				class="nav-backdrop"
				id="nav-backdrop"
				tabindex="-1"
				aria-hidden="true"
			>
			</button>
			<nav class="nav" id="site-nav" aria-label="Main">
				<ul>
					{
						nav.map(({ href, label }) => {
							const active =
								href === '/#contact'
									? false
									: href === '/'
										? pathname === '/'
										: pathname === href || pathname.startsWith(href + '/');
							return (
								<li>
									<a
										href={href}
										class:list={['nav-link', { active }]}
										aria-current={active ? 'page' : undefined}
									>
										{label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</header>
		<slot />
		<SocialFooter />
		<script is:inline>
			(function () {
				var k = 'kspice-theme';
				var btn = document.getElementById('theme-toggle');
				if (!btn) return;

				function labelFor(theme) {
					return theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
				}

				function syncUi(theme) {
					btn.setAttribute('aria-label', labelFor(theme));
					btn.classList.toggle('theme-toggle--dark', theme === 'dark');
					btn.classList.toggle('theme-toggle--light', theme === 'light');
				}

				syncUi(document.documentElement.getAttribute('data-theme') || 'dark');

				btn.addEventListener('click', function () {
					var cur = document.documentElement.getAttribute('data-theme') || 'dark';
					var next = cur === 'dark' ? 'light' : 'dark';
					document.documentElement.setAttribute('data-theme', next);
					localStorage.setItem(k, next);
					syncUi(next);
				});
			})();
		</script>
		<script is:inline>
			(function () {
				var mq = window.matchMedia('(min-width: 52rem)');

				function els() {
					return {
						header: document.querySelector('.site-header'),
						toggle: document.getElementById('menu-toggle'),
						backdrop: document.getElementById('nav-backdrop'),
						nav: document.getElementById('site-nav'),
					};
				}

				function isDesktop() {
					return mq.matches;
				}

				function isOpen(h) {
					return h && h.classList.contains('is-menu-open');
				}

				function syncNavAria() {
					var e = els();
					if (!e.header || !e.nav) return;
					if (isDesktop() || isOpen(e.header)) e.nav.removeAttribute('aria-hidden');
					else e.nav.setAttribute('aria-hidden', 'true');
				}

				function closeMenu(returnFocus) {
					var e = els();
					if (!e.header || !e.toggle || !e.nav) return;
					var wasOpen = isOpen(e.header);
					e.header.classList.remove('is-menu-open');
					e.toggle.setAttribute('aria-expanded', 'false');
					e.toggle.setAttribute('aria-label', 'Open menu');
					document.body.style.overflow = '';
					syncNavAria();
					if (returnFocus && wasOpen) e.toggle.focus();
				}

				function openMenu() {
					var e = els();
					if (!e.header || !e.toggle || !e.nav) return;
					e.header.classList.add('is-menu-open');
					e.toggle.setAttribute('aria-expanded', 'true');
					e.toggle.setAttribute('aria-label', 'Close menu');
					document.body.style.overflow = 'hidden';
					syncNavAria();
					var first = e.nav.querySelector('a');
					if (first) {
						window.requestAnimationFrame(function () {
							first.focus();
						});
					}
				}

				function onToggleClick() {
					var e = els();
					if (!e.header || !e.toggle || !e.nav || isDesktop()) return;
					if (isOpen(e.header)) closeMenu(true);
					else openMenu();
				}

				function bindNavLinks() {
					var e = els();
					if (!e.nav) return;
					e.nav.querySelectorAll('a').forEach(function (link) {
						link.addEventListener('click', function () {
							if (!isDesktop()) closeMenu(false);
						});
					});
				}

				var e0 = els();
				if (!e0.header || !e0.toggle || !e0.nav) return;

				e0.toggle.addEventListener('click', onToggleClick);
				if (e0.backdrop) e0.backdrop.addEventListener('click', function () {
					closeMenu(true);
				});

				bindNavLinks();

				document.addEventListener('keydown', function (ev) {
					if (ev.key === 'Escape' && !isDesktop()) {
						var e = els();
						if (e.header && isOpen(e.header)) closeMenu(true);
					}
				});

				mq.addEventListener('change', function () {
					closeMenu(false);
					syncNavAria();
				});

				syncNavAria();
			})();
		</script>
	</body>
</html>

<style>
	.site-header {
		position: relative;
		z-index: 50;
		display: grid;
		align-items: center;
		column-gap: 1rem;
		padding: 0.75rem max(1rem, env(safe-area-inset-right)) 0.75rem max(1rem, env(safe-area-inset-left));
		border-bottom: 2px solid var(--border);
		background: var(--bg-elevated);
		grid-template-columns: minmax(0, 1fr) auto;
		grid-template-rows: auto;
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease;
	}

	.brand {
		grid-column: 1;
		grid-row: 1;
		font-weight: 700;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.02em;
		min-width: 0;
	}

	.brand:hover {
		color: var(--teal-dark);
	}

	.header-tools {
		grid-column: 2;
		grid-row: 1;
		display: flex;
		align-items: center;
		justify-self: end;
		gap: 0.45rem;
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 2px solid var(--border);
		border-radius: 10px;
		background: var(--bg);
		color: var(--ink);
		cursor: pointer;
		font-size: 1.125rem;
		line-height: 1;
		flex-shrink: 0;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.menu-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 2px solid var(--border);
		border-radius: 10px;
		background: var(--bg);
		color: var(--ink);
		cursor: pointer;
		flex-shrink: 0;
		-webkit-tap-highlight-color: transparent;
		touch-action: manipulation;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.menu-toggle:hover {
		border-color: var(--teal);
		color: var(--teal-dark);
	}

	.menu-toggle:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: 2px;
	}

	.menu-toggle__bars {
		display: flex;
		flex-direction: column;
		gap: 5px;
		width: 1.125rem;
	}

	.menu-toggle__bar {
		display: block;
		height: 2px;
		width: 100%;
		background: currentColor;
		border-radius: 1px;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
		transform-origin: center;
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}

	.site-header.is-menu-open .menu-toggle__bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.nav-backdrop {
		position: fixed;
		inset: 0;
		z-index: 1000;
		margin: 0;
		padding: 0;
		border: none;
		background: color-mix(in srgb, var(--ink) 45%, transparent);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.2s ease,
			visibility 0.2s ease;
	}

	.site-header.is-menu-open .nav-backdrop {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.nav {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		z-index: 1001;
		width: min(19.5rem, 90vw);
		margin: 0;
		padding: max(4.65rem, calc(0.75rem + env(safe-area-inset-top))) max(1rem, env(safe-area-inset-right)) 1.5rem
			max(1.25rem, env(safe-area-inset-left));
		background: var(--bg-elevated);
		border-left: 1px solid var(--border);
		box-shadow: -16px 0 48px color-mix(in srgb, var(--ink) 14%, transparent);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		transform: translateX(100%);
		visibility: hidden;
		transition:
			transform 0.25s ease,
			visibility 0.25s ease;
	}

	.site-header.is-menu-open .nav {
		transform: translateX(0);
		visibility: visible;
	}

	.nav ul {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.35rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-link {
		display: block;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.25;
		padding: 0.75rem 0.85rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: var(--bg);
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background-color 0.15s ease;
	}

	.nav-link:hover {
		color: var(--teal-dark);
		border-color: var(--teal-soft);
	}

	.nav-link.active {
		color: var(--purple-dark);
		border-color: var(--purple);
		background: color-mix(in srgb, var(--purple) 10%, var(--bg));
	}

	.theme-toggle:hover {
		border-color: var(--teal);
		color: var(--teal-dark);
	}

	.theme-toggle:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: 2px;
	}

	.theme-toggle__icon {
		display: none;
	}

	.theme-toggle--dark .theme-toggle__icon--sun {
		display: block;
	}

	.theme-toggle--light .theme-toggle__icon--moon {
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.nav,
		.nav-backdrop,
		.menu-toggle__bar {
			transition: none !important;
		}
	}

	@media (min-width: 52rem) {
		.site-header {
			grid-template-columns: auto minmax(0, 1fr) auto;
			padding: 1rem max(1.5rem, env(safe-area-inset-right)) 1rem max(1.5rem, env(safe-area-inset-left));
		}

		.brand {
			grid-column: 1;
			grid-row: 1;
		}

		.header-tools {
			display: contents;
		}

		.menu-toggle {
			display: none !important;
		}

		.nav-backdrop {
			display: none !important;
		}

		.nav {
			position: static;
			grid-column: 2;
			grid-row: 1;
			width: auto;
			height: auto;
			justify-self: end;
			padding: 0;
			border: none;
			box-shadow: none;
			overflow: visible;
			transform: none;
			visibility: visible;
		}

		.nav ul {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: flex-end;
			gap: 0.2rem 1.1rem;
		}

		.nav-link {
			font-size: 0.9375rem;
			font-weight: 500;
			padding: 0.25rem 0;
			border: none;
			border-radius: 0;
			background: transparent;
			border-bottom: 2px solid transparent;
		}

		.nav-link:hover {
			border-bottom-color: var(--teal-soft);
		}

		.nav-link.active {
			font-weight: 600;
			border-bottom-color: var(--purple);
			background: transparent;
		}

		.theme-toggle {
			grid-column: 3;
			grid-row: 1;
			justify-self: end;
			width: 2.5rem;
			height: 2.5rem;
		}
	}

</style>
