---
import '../styles/global.css';
import SocialFooter from '../components/SocialFooter.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'kspice.dev',
	description = 'Programming, woodworking, and more.',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const nav = [
	{ href: '/', label: 'Home' },
	{ href: '/programming', label: 'Programming Tutorials' },
	{ href: '/projects', label: 'Documented Projects' },
	{ href: '/woodworking', label: 'Woodworking' },
	{ href: '/resume', label: 'Resume' },
	{ href: '/#contact', label: 'Contact' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="color-scheme" content="dark light" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title === 'kspice.dev' ? title : `${title} · kspice.dev`}</title>
		<script is:inline>
			(function () {
				var k = 'kspice-theme';
				var t = localStorage.getItem(k);
				if (t !== 'light' && t !== 'dark') t = 'dark';
				document.documentElement.setAttribute('data-theme', t);
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">kspice.dev</a>
			<nav class="nav" aria-label="Main">
				<ul>
					{
						nav.map(({ href, label }) => {
							const active =
								href === '/#contact'
									? false
									: href === '/'
										? pathname === '/'
										: pathname === href || pathname.startsWith(href + '/');
							return (
								<li>
									<a
										href={href}
										class:list={['nav-link', { active }]}
										aria-current={active ? 'page' : undefined}
									>
										{label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
			<button
				type="button"
				class="theme-toggle theme-toggle--dark"
				id="theme-toggle"
				aria-label="Switch to light mode"
			>
				<span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">☀</span>
				<span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">☾</span>
			</button>
		</header>
		<slot />
		<SocialFooter />
		<script is:inline>
			(function () {
				var k = 'kspice-theme';
				var btn = document.getElementById('theme-toggle');
				if (!btn) return;

				function labelFor(theme) {
					return theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
				}

				function syncUi(theme) {
					btn.setAttribute('aria-label', labelFor(theme));
					btn.classList.toggle('theme-toggle--dark', theme === 'dark');
					btn.classList.toggle('theme-toggle--light', theme === 'light');
				}

				syncUi(document.documentElement.getAttribute('data-theme') || 'dark');

				btn.addEventListener('click', function () {
					var cur = document.documentElement.getAttribute('data-theme') || 'dark';
					var next = cur === 'dark' ? 'light' : 'dark';
					document.documentElement.setAttribute('data-theme', next);
					localStorage.setItem(k, next);
					syncUi(next);
				});
			})();
		</script>
	</body>
</html>

<style>
	.site-header {
		display: grid;
		align-items: center;
		column-gap: 1rem;
		row-gap: 0.65rem;
		padding: 0.75rem max(1rem, env(safe-area-inset-right)) 0.75rem max(1rem, env(safe-area-inset-left));
		border-bottom: 2px solid var(--border);
		background: var(--bg-elevated);
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease;
	}

	/* Narrow: title row + full-width scrollable nav */
	.site-header {
		grid-template-columns: minmax(0, 1fr) auto;
		grid-template-rows: auto auto;
	}

	.brand {
		grid-column: 1;
		grid-row: 1;
		font-weight: 700;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.02em;
		min-width: 0;
	}

	.brand:hover {
		color: var(--teal-dark);
	}

	.theme-toggle {
		grid-column: 2;
		grid-row: 1;
		justify-self: end;
		align-self: center;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 2px solid var(--border);
		border-radius: 10px;
		background: var(--bg);
		color: var(--ink);
		cursor: pointer;
		font-size: 1.125rem;
		line-height: 1;
		flex-shrink: 0;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.nav {
		grid-column: 1 / -1;
		grid-row: 2;
		min-width: 0;
		padding: 0.35rem 0 0.15rem;
		border-top: 1px solid var(--border);
	}

	.nav ul {
		display: flex;
		flex-wrap: nowrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0.15rem 0 0.35rem;
		overflow-x: auto;
		overscroll-behavior-x: contain;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
		touch-action: pan-x;
	}

	.nav ul::-webkit-scrollbar {
		display: none;
	}

	.nav li {
		flex-shrink: 0;
	}

	.nav-link {
		display: block;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.8125rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		padding: 0.45rem 0.7rem;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: var(--bg);
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background-color 0.15s ease;
	}

	.nav-link:hover {
		color: var(--teal-dark);
		border-color: var(--teal-soft);
	}

	.nav-link.active {
		color: var(--purple-dark);
		border-color: var(--purple);
		background: color-mix(in srgb, var(--purple) 10%, var(--bg));
	}

	.theme-toggle:hover {
		border-color: var(--teal);
		color: var(--teal-dark);
	}

	.theme-toggle:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: 2px;
	}

	.theme-toggle__icon {
		display: none;
	}

	.theme-toggle--dark .theme-toggle__icon--sun {
		display: block;
	}

	.theme-toggle--light .theme-toggle__icon--moon {
		display: block;
	}

	@media (min-width: 52rem) {
		.site-header {
			grid-template-columns: auto minmax(0, 1fr) auto;
			grid-template-rows: auto;
			padding: 1rem max(1.5rem, env(safe-area-inset-right)) 1rem max(1.5rem, env(safe-area-inset-left));
			row-gap: 0;
		}

		.brand {
			grid-column: 1;
			grid-row: 1;
		}

		.nav {
			grid-column: 2;
			grid-row: 1;
			justify-self: end;
			margin: 0;
			padding: 0;
			border-top: none;
		}

		.nav ul {
			flex-wrap: wrap;
			justify-content: flex-end;
			overflow: visible;
			padding: 0;
			gap: 0.2rem 1.1rem;
			touch-action: auto;
		}

		.nav-link {
			font-size: 0.9375rem;
			font-weight: 500;
			padding: 0.25rem 0;
			border: none;
			border-radius: 0;
			background: transparent;
			border-bottom: 2px solid transparent;
		}

		.nav-link:hover {
			border-bottom-color: var(--teal-soft);
		}

		.nav-link.active {
			font-weight: 600;
			border-bottom-color: var(--purple);
			background: transparent;
		}

		.theme-toggle {
			grid-column: 3;
			grid-row: 1;
			width: 2.5rem;
			height: 2.5rem;
		}
	}

</style>
