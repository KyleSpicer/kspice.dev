---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
---

<Layout
	title="Resume"
	description="Resume and professional background — kspice.dev."
>
	<main class="main">
		<h1>Resume</h1>
		<p class="lede">
			Replace this placeholder with your experience, skills, and education—or link to a PDF in{' '}
			<code class="inline-code">public/</code>.
		</p>
		<section class="section" aria-labelledby="placeholder-heading">
			<h2 id="placeholder-heading">Summary</h2>
			<p>
				Add your summary here. You can use multiple sections (Experience, Education, Skills) as
				plain HTML or markdown via a content file later.
			</p>
		</section>
	</main>
</Layout>
