---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
---

<Layout
	title="Woodworking"
	description="Woodworking projects, tutorials, and videos on kspice.dev."
>
	<main class="main">
		<h1>Woodworking</h1>
		<p class="lede">
			Shop projects, techniques, and embedded videos or links to your channel, without storing large
			files in Git.
		</p>
		<section class="section" aria-labelledby="soon-heading">
			<h2 id="soon-heading">Coming soon</h2>
			<p>
				Add build articles in markdown or embed YouTube/Vimeo here when you are ready.
			</p>
		</section>
	</main>
</Layout>
