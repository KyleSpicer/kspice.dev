const toAnchorId = (text) =>
	text
		.toLowerCase()
		.replace(/[^a-z0-9\s-]/g, '')
		.trim()
		.replace(/\s+/g, '-');
---

<Layout
	title="Book Recommendations"
	description="Book recommendations and affiliate links on kspice.dev."
>
	<main class="main recommendations">
		<h1>Book Recommendations</h1>
		<p class="lede">A running list of books I have used and recommend.</p>
		<section class="section" aria-labelledby="toc-heading">
			<h2 id="toc-heading">Table of contents</h2>
			<ul>
				{bookCategories.map((category) => (
					<li>
						<a href={`#${toAnchorId(category.name)}`}>{category.name}</a>
					</li>
				))}
			</ul>
		</section>
		<section class="section" aria-labelledby="books-heading">
			<h2 id="books-heading">Books</h2>
			{bookCategories.map((category) => (
				<section class="section" id={toAnchorId(category.name)}>
					<h3>
						<a href={`#${toAnchorId(category.name)}`}>{category.name}</a>
					</h3>
					<ul class="cards">
						{category.books.map((book) => (
							<li>
								<a class="card" href={book.href} target="_blank" rel="noopener noreferrer sponsored">
									<h4>{book.title}</h4>
									<p>{book.description}</p>
								</a>
							</li>
						))}
					</ul>
				</section>
			))}
		</section>
	</main>
</Layout>

<style>
	.recommendations ul.cards {
		gap: 0.65rem;
	}

	.recommendations a.card {
		padding: 0.85rem 1rem;
		border-radius: 8px;
	}

	.recommendations a.card h4 {
		margin: 0 0 0.2rem;
		font-size: 1rem;
	}

	.recommendations a.card p {
		font-size: 0.95rem;
	}
</style>
