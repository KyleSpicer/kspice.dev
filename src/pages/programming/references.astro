---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { formatListDate } from '../../utils/formatListDate';
import { referenceCards } from '../../data/programming/references';

const sorted = [...referenceCards].sort((a, b) => {
	if (!a.published) return 1;
	if (!b.published) return -1;
	return b.published.localeCompare(a.published);
});
---

<Layout
	title="References"
	description="Developer references: links and files recommended on kspice.dev."
>
	<main class="main">
		<h1>References</h1>
		<p class="lede">Links and files I use or recommend for day-to-day development.</p>
		<section class="section" aria-labelledby="refs-list-heading">
			<h2 id="refs-list-heading">Curated links</h2>
			<ul class="cards">
				{
					sorted.map((card) => (
						<li>
							<a
								class="card"
								href={card.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								<h3>
									{card.title.map((part) =>
										'code' in part ? (
											<span class="inline-code">{part.code}</span>
										) : (
											part.text
										),
									)}
								</h3>
								<p>
									{card.description.map((part) =>
										'code' in part ? (
											<span class="inline-code">{part.code}</span>
										) : (
											part.text
										),
									)}
								</p>
								{card.published ? (
									<p class="card-meta">
										<time datetime={card.published}>
											{formatListDate(card.published)}
										</time>
									</p>
								) : null}
							</a>
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>
