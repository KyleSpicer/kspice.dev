---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { formatListDate } from '../../utils/formatListDate';
import { referenceCards } from '../../data/programming/references';
import { getReferencesDataLastUpdatedIsoDay } from '../../utils/programmingSourceDates';

const dataFileDay = getReferencesDataLastUpdatedIsoDay();

const enriched = referenceCards.map((card) => ({
	card,
	activityIsoDay: dataFileDay ?? card.published ?? null,
}));

const sorted = [...enriched].sort((a, b) => {
	const ad = a.activityIsoDay ?? '';
	const bd = b.activityIsoDay ?? '';
	return bd.localeCompare(ad);
});
---

<Layout
	title="References"
	description="Developer references: links and files recommended on kspice.dev."
>
	<main class="main">
		<h1>References</h1>
		<p class="lede">Links and files I use or recommend for day-to-day development.</p>
		<section class="section" aria-labelledby="refs-list-heading">
			<h2 id="refs-list-heading">Curated links</h2>
			<ul class="cards">
				{
					sorted.map(({ card, activityIsoDay }) => (
						<li>
							<a
								class="card"
								href={card.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								<h3>
									{card.title.map((part) =>
										'code' in part ? (
											<span class="inline-code">{part.code}</span>
										) : (
											part.text
										),
									)}
								</h3>
								<p>
									{card.description.map((part) =>
										'code' in part ? (
											<span class="inline-code">{part.code}</span>
										) : (
											part.text
										),
									)}
								</p>
								{activityIsoDay ? (
									<p class="card-meta">
										<time class="card-meta-muted" datetime={activityIsoDay}>
											Updated {formatListDate(activityIsoDay)}
										</time>
									</p>
								) : null}
							</a>
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>
