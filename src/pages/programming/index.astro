---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { sitePath } from '../../utils/sitePath';
import { tutorialCards } from '../../data/programming/tutorials';
import { referenceCards } from '../../data/programming/references';
import {
	getReferencesDataLastUpdatedIsoDay,
	getTutorialSourceLastUpdatedIsoDay,
} from '../../utils/programmingSourceDates';
import { formatListDate } from '../../utils/formatListDate';

const tutorialsLatestIso = tutorialCards
	.map((t) => getTutorialSourceLastUpdatedIsoDay(t.slug, t.published) ?? t.published)
	.filter((d): d is string => Boolean(d))
	.reduce<string | null>(
		(latest, day) => (!latest || day > latest ? day : latest),
		null,
	);

const referencesLatestIso =
	getReferencesDataLastUpdatedIsoDay() ??
	referenceCards.find((c) => c.published)?.published ??
	null;
---

<Layout
	title="Programming"
	description="Programming tutorials, developer references, and lessons on kspice.dev."
>
	<main class="main">
		<h1>Programming</h1>
		<p class="lede">
			Tutorials and reference material I maintain for myself and other developers.
		</p>
		<section class="section" aria-labelledby="sections-heading">
			<h2 id="sections-heading">Contents</h2>
			<ul class="cards">
				<li>
					<a class="card" href={sitePath('/programming/tutorials')}>
						<h3>Tutorials</h3>
						<p>Step-by-step lessons and notes.</p>
						{tutorialsLatestIso ? (
							<p class="card-meta">
								<time class="card-meta-muted" datetime={tutorialsLatestIso}>
									Last updated {formatListDate(tutorialsLatestIso)}
								</time>
							</p>
						) : null}
					</a>
				</li>
				<li>
					<a class="card" href={sitePath('/programming/references')}>
						<h3>References</h3>
						<p>Curated links and files worth bookmarking for day-to-day development.</p>
						{referencesLatestIso ? (
							<p class="card-meta">
								<time class="card-meta-muted" datetime={referencesLatestIso}>
									Last updated {formatListDate(referencesLatestIso)}
								</time>
							</p>
						) : null}
					</a>
				</li>
			</ul>
		</section>
		<section class="section" aria-labelledby="contribute-heading">
			<h2 id="contribute-heading">Contribute</h2>
			<p>
				If you’d like to contribute to this, please{' '}
				<a href="mailto:kyledspicer@gmail.com">email me</a>
				{' '}
				and we can get it added!
			</p>
		</section>
	</main>
</Layout>
