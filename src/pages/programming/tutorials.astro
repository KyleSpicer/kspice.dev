---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { sitePath } from '../../utils/sitePath';
import { formatListDate } from '../../utils/formatListDate';
import { tutorialCards } from '../../data/programming/tutorials';

const sorted = [...tutorialCards].sort((a, b) => {
	if (!a.published) return 1;
	if (!b.published) return -1;
	return b.published.localeCompare(a.published);
});
---

<Layout
	title="Tutorials"
	description="Programming tutorials and lessons on kspice.dev."
>
	<main class="main">
		<h1>Tutorials</h1>
		<p class="lede">
			Too often, developers research and create unique solutions that go undocumented and forgotten.
			The purpose of this section is to document and archive tutorials for future reference.
		</p>
		<section class="section" aria-labelledby="tutorials-list-heading">
			<h2 id="tutorials-list-heading">All tutorials</h2>
			<ul class="cards">
				{
					sorted.map((t) => (
						<li>
							<a class="card" href={sitePath(`/programming/${t.slug}`)}>
								<h3>{t.title}</h3>
								<p>{t.description}</p>
								{t.published ? (
									<p class="card-meta">
										<time datetime={t.published}>{formatListDate(t.published)}</time>
									</p>
								) : null}
							</a>
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>
