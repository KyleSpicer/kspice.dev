---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { sitePath } from '../../utils/sitePath';
import { woodworkingProjects } from '../../data/woodworking/projects';

const sorted = [...woodworkingProjects].sort((a, b) => {
	if (!a.completed) return 1;
	if (!b.completed) return -1;
	return b.completed.localeCompare(a.completed);
});
---

<Layout
	title="Woodworking"
	description="Documented shop projects and galleries on kspice.dev."
>
	<main class="main">
		<h1>Woodworking</h1>
		<p class="lede">
			Built pieces and shop notes from Spicer Woodworking. Link to Facebook in Contact.
		</p>
		<section class="section" aria-labelledby="projects-heading">
			<h2 id="projects-heading">Projects</h2>
			<ul class="cards">
				{
					sorted.map((p) => {
						const n = p.images.length;
						const photoLine = n === 0 ? 'No photos yet' : `${n} photo${n === 1 ? '' : 's'}`;
						const meta = [photoLine, p.completed].filter(Boolean).join(' · ');
						const thumb = p.listThumbnail ?? (p.images[0]
							? { src: p.images[0].src, alt: p.images[0].alt }
							: null);
						const thumbHref = thumb ? sitePath(thumb.src) : null;
						return (
							<li>
								<a
									class:list={['card', 'wood-project-card', { 'wood-project-card--thumb': !!thumbHref }]}
									href={sitePath(`/woodworking/${p.slug}`)}
								>
									{
										thumbHref ? (
											<span class="wood-project-card__thumb" aria-hidden="true">
												<img
													src={thumbHref}
													alt=""
													width="120"
													height="90"
													loading="lazy"
													decoding="async"
												/>
											</span>
										) : null
									}
									<span class="wood-project-card__body">
										<h3>{p.title}</h3>
										<p>{p.listSummary ?? p.description}</p>
										<p class="card-meta">{meta}</p>
									</span>
								</a>
							</li>
						);
					})
				}
			</ul>
		</section>
	</main>
</Layout>
