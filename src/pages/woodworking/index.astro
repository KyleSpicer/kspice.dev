---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { sitePath } from '../../utils/sitePath';
import { woodworkingProjects } from '../../data/woodworking/projects';

const sorted = [...woodworkingProjects].sort((a, b) => {
	if (!a.completed) return 1;
	if (!b.completed) return -1;
	return b.completed.localeCompare(a.completed);
});
---

<Layout
	title="Woodworking"
	description="Documented shop projects and galleries on kspice.dev."
>
	<main class="main">
		<h1>Woodworking</h1>
		<p class="lede">
			Built pieces and shop notes, each with dated photos. Open a project for a short write-up and an
			image grid—click any photo to view it full size with the same caption.
		</p>
		<section class="section" aria-labelledby="projects-heading">
			<h2 id="projects-heading">Projects</h2>
			<ul class="cards">
				{
					sorted.map((p) => {
						const n = p.images.length;
						const photoLine = n === 0 ? 'No photos yet' : `${n} photo${n === 1 ? '' : 's'}`;
						const meta = [photoLine, p.completed].filter(Boolean).join(' · ');
						const thumb = p.listThumbnail ?? (p.images[0]
							? { src: p.images[0].src, alt: p.images[0].alt }
							: null);
						const thumbHref = thumb ? sitePath(thumb.src) : null;
						return (
							<li>
								<a
									class:list={['card', 'wood-project-card', { 'wood-project-card--thumb': !!thumbHref }]}
									href={sitePath(`/woodworking/${p.slug}`)}
								>
									{
										thumbHref ? (
											<span class="wood-project-card__thumb" aria-hidden="true">
												<img
													src={thumbHref}
													alt=""
													width="120"
													height="90"
													loading="lazy"
													decoding="async"
												/>
											</span>
										) : null
									}
									<span class="wood-project-card__body">
										<h3>{p.title}</h3>
										<p>{p.description}</p>
										<p class="card-meta">{meta}</p>
									</span>
								</a>
							</li>
						);
					})
				}
			</ul>
		</section>
	</main>
</Layout>

<style>
	.wood-project-card--thumb {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: 1rem;
	}

	.wood-project-card__thumb {
		position: relative;
		flex-shrink: 0;
		width: 6.75rem;
		aspect-ratio: 4 / 3;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--border);
		background: var(--purple-soft);
	}

	.wood-project-card__thumb img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.wood-project-card__body {
		flex: 1;
		min-width: 0;
	}

	/* Titles inside horizontal cards: tighten top edge next to thumbnail */
	.wood-project-card--thumb .wood-project-card__body :is(h2, h3):first-child {
		margin-top: 0;
	}

	.card-meta {
		margin: 0.75rem 0 0;
		font-size: 0.875rem;
		color: var(--teal-dark);
		font-weight: 600;
	}
</style>
