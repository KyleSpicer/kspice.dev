---
import Layout from '../../layouts/Layout.astro';
import '../../styles/page-main.css';
import { sitePath } from '../../utils/sitePath';
import { formatListDate } from '../../utils/formatListDate';
import { woodworkingProjects } from '../../data/woodworking/projects';

const sorted = [...woodworkingProjects].sort((a, b) => {
	if (!a.completed) return 1;
	if (!b.completed) return -1;
	return b.completed.localeCompare(a.completed);
});

const heroSrc = sitePath('/images/woodworking/cnc-and-handmade.png');
---

<Layout
	title="Woodworking"
	description="Documented shop projects and galleries on kspice.dev."
>
	<main class="main">
		<figure class="wood-index-hero">
			<img
				class="wood-index-hero__img"
				src={heroSrc}
				alt="CNC and handmade woodworking"
				loading="eager"
				decoding="async"
			/>
		</figure>
		<h1>Woodworking</h1>
		<p class="lede">
			Built pieces and shop notes from Spicer Woodworking. Link to Facebook in Contact.
		</p>
		<section class="section" aria-labelledby="projects-heading">
			<h2 id="projects-heading">Projects</h2>
			<ul class="cards">
				{
					sorted.map((p) => {
						const n = p.images.length;
						const photoLine = n === 0 ? 'No photos yet' : `${n} photo${n === 1 ? '' : 's'}`;
						const thumb = p.listThumbnail ?? (p.images[0]
							? { src: p.images[0].src, alt: p.images[0].alt }
							: null);
						const thumbHref = thumb ? sitePath(thumb.src) : null;
						return (
							<li>
								<a
									class:list={['card', 'wood-project-card', { 'wood-project-card--thumb': !!thumbHref }]}
									href={sitePath(`/woodworking/${p.slug}`)}
								>
									{
										thumbHref ? (
											<span class="wood-project-card__thumb" aria-hidden="true">
												<img
													src={thumbHref}
													alt=""
													width="120"
													height="90"
													loading="lazy"
													decoding="async"
												/>
											</span>
										) : null
									}
									<span class="wood-project-card__body">
										<h3>{p.title}</h3>
										<p>{p.listSummary ?? p.description}</p>
										<p class="card-meta">
											<span class="card-meta-aside">{photoLine}</span>
											{p.completed ? (
												<time class="card-meta-pill" datetime={p.completed}>
													Completed {formatListDate(p.completed)}
												</time>
											) : null}
										</p>
									</span>
								</a>
							</li>
						);
					})
				}
			</ul>
		</section>
	</main>
</Layout>

<style>
	.wood-index-hero {
		margin: 0 auto 1.75rem;
		padding: 0;
		border: none;
		max-width: min(28rem, 92%);
	}

	.wood-index-hero__img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 12px;
		border: 2px solid var(--border);
		box-shadow: 0 4px 24px color-mix(in srgb, var(--purple) 10%, transparent);
	}
</style>
