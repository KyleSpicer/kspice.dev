---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
import { sitePath } from '../utils/sitePath';

/** Home hero: blue/teal tile mark (`public/images/logo/`). */
const heroLogoSrc = sitePath('/images/logo/KSPICE.DEV-Logo-01.png');
---

<Layout
	title="kspice.dev"
>
	<main class="main">
		<h1 class="welcome-stack">
			<span class="welcome-line">Welcome to</span>
			<img
				class="home-hero-logo"
				src={heroLogoSrc}
				alt="kspice.dev"
				width="1000"
				height="1000"
				loading="eager"
				decoding="async"
			/>
		</h1>
		<ul class="cards">
			<li>
				<a class="card" href={sitePath('/programming')}>
					<h2>Programming</h2>
					<p>Tutorials, references, and teaching notes.</p>
				</a>
			</li>
			<li>
				<a class="card" href={sitePath('/homelab')}>
					<h2>HomeLab Blog</h2>
					<p>HP DL380 Gen 9 HomeLab adventures.</p>
				</a>
			</li>
			<li>
				<a class="card" href={sitePath('/woodworking')}>
					<h2>Woodworking</h2>
					<p>Projects, photos, and notes from the shop.</p>
				</a>
			</li>
			<li>
				<a class="card" href={sitePath('/resume')}>
					<h2>Resume</h2>
					<p>Experience and background.</p>
				</a>
			</li>
			<li>
				<a class="card" href={sitePath('/recommendations')}>
					<h2>Book Recommendations</h2>
					<p>Books and affiliate picks.</p>
				</a>
			</li>
		</ul>
	</main>
</Layout>

<style>
	.welcome-stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1rem;
		margin: 0 0 2.25rem;
	}

	.welcome-line {
		display: block;
		width: 100%;
	}

	.home-hero-logo {
		width: min(26rem, 100%);
		height: auto;
		display: block;
		border: none;
		border-radius: 12px;
	}
</style>
