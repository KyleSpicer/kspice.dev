---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="kspice.dev"
	description="Kyle Spicer’s site: programming tutorials, project documentation, woodworking, and more."
>
	<main class="main">
		<h1>Welcome</h1>
		<p class="lede">
			Kyle Spicer’s site for recording programming tutorials, documenting projects,
			displaying woodworking projects, and more.
		</p>
		<ul class="cards">
			<li>
				<a class="card" href="/programming">
					<h2>Programming Tutorials</h2>
					<p>Lessons, walkthroughs, and teaching notes.</p>
				</a>
			</li>
			<li>
				<a class="card" href="/projects">
					<h2>Documented Projects</h2>
					<p>Write-ups and documentation for things you have built.</p>
				</a>
			</li>
			<li>
				<a class="card" href="/woodworking">
					<h2>Woodworking</h2>
					<p>Builds, techniques, and video links.</p>
				</a>
			</li>
			<li>
				<a class="card" href="/resume">
					<h2>Resume</h2>
					<p>Experience and background.</p>
				</a>
			</li>
			<li>
				<a class="card" href="/recommendations">
					<h2>Product Recommendations</h2>
					<p>Books, tools, gadgets, and affiliate picks.</p>
				</a>
			</li>
		</ul>
	</main>
</Layout>

<style>
	.main {
		max-width: 42rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
	}

	h1 {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem;
		color: var(--ink);
	}

	.lede {
		margin: 0 0 2rem;
		color: var(--muted);
		font-size: 1.0625rem;
	}

	.cards {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.card {
		display: block;
		padding: 1.25rem 1.5rem;
		background: var(--bg-elevated);
		border: 2px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		color: var(--ink);
		transition:
			border-color 0.15s ease,
			box-shadow 0.15s ease,
			background-color 0.2s ease;
	}

	.card:hover {
		border-color: var(--teal);
		box-shadow: 0 4px 20px color-mix(in srgb, var(--purple) 12%, transparent);
	}

	.card h2 {
		margin: 0 0 0.35rem;
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--purple-dark);
	}

	.card p {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--muted);
	}
</style>
