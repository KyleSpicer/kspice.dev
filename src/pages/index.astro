---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
import { sitePath } from '../utils/sitePath';
import { getCollection } from 'astro:content';
import { tutorialCards } from '../data/programming/tutorials';
import { referenceCards } from '../data/programming/references';
import { woodworkingProjects } from '../data/woodworking/projects';
import { homepageUpdates } from '../data/homepage-updates';
import { formatListDate } from '../utils/formatListDate';
import { formatMarkdownDate } from '../utils/formatMarkdownDate';
import {
	getReferencesDataLastUpdatedIsoDay,
	getTutorialSourceLastUpdatedIsoDay,
} from '../utils/programmingSourceDates';

/** Home hero: blue/teal tile mark (`public/images/logo/`). */
const heroLogoSrc = sitePath('/images/logo/KSPICE.DEV-Logo-01.png');

type HomeCard = {
	href: string;
	title: string;
	description: string;
	lastUpdated: Date | null;
	baseOrder: number;
};

const homelabPosts = await getCollection('homelab');
const homelabSpecs = await getCollection('homelabSpecs');
const homelabLatest = [...homelabPosts, ...homelabSpecs].reduce<Date | null>((latest, entry) => {
	const entryDate = (entry.data.updated ?? entry.data.published) ?? null;
	if (!entryDate) return latest;
	if (!latest) return entryDate;
	return entryDate > latest ? entryDate : latest;
}, null);

const tutorialActivityDays = tutorialCards
	.map((t) => getTutorialSourceLastUpdatedIsoDay(t.slug, t.published) ?? t.published)
	.filter((d): d is string => Boolean(d));
const refsDataDay = getReferencesDataLastUpdatedIsoDay();
const referenceFallback =
	referenceCards.find((c) => c.published)?.published ?? null;
const programmingActivityCandidates = [
	...tutorialActivityDays,
	...(refsDataDay ? [refsDataDay] : []),
	...(referenceFallback && !refsDataDay ? [referenceFallback] : []),
];
const programmingLatestIso = programmingActivityCandidates.reduce<string | null>(
	(latest, day) => {
		if (!latest) return day;
		return day > latest ? day : latest;
	},
	null,
);
const programmingLatest = programmingLatestIso ? new Date(programmingLatestIso + 'T12:00:00') : null;

const woodworkingLatestIso = woodworkingProjects.reduce<string | null>((latest, project) => {
	if (!project.completed) return latest;
	if (!latest) return project.completed;
	return project.completed > latest ? project.completed : latest;
}, null);
const woodworkingLatest = woodworkingLatestIso ? new Date(woodworkingLatestIso + 'T12:00:00') : null;
const resumeLatest = new Date(homepageUpdates.resume + 'T12:00:00');
const recommendationsLatest = new Date(homepageUpdates.recommendations + 'T12:00:00');

const homeCards: HomeCard[] = [
	{
		href: sitePath('/programming'),
		title: 'Programming',
		description: 'Tutorials, references, and teaching notes.',
		lastUpdated: programmingLatest,
		baseOrder: 1,
	},
	{
		href: sitePath('/homelab'),
		title: 'HomeLab Blog',
		description: 'HP DL380 Gen 9 HomeLab adventures.',
		lastUpdated: homelabLatest,
		baseOrder: 2,
	},
	{
		href: sitePath('/woodworking'),
		title: 'Woodworking',
		description: 'Projects, photos, and notes from the shop.',
		lastUpdated: woodworkingLatest,
		baseOrder: 3,
	},
	{
		href: sitePath('/resume'),
		title: 'Resume',
		description: 'Experience and background.',
		lastUpdated: resumeLatest,
		baseOrder: 4,
	},
	{
		href: sitePath('/recommendations'),
		title: 'Book Recommendations',
		description: 'Books and affiliate picks.',
		lastUpdated: recommendationsLatest,
		baseOrder: 5,
	},
].sort((a, b) => {
	const aTime = a.lastUpdated?.valueOf() ?? -1;
	const bTime = b.lastUpdated?.valueOf() ?? -1;
	if (bTime !== aTime) return bTime - aTime;
	return a.baseOrder - b.baseOrder;
});

const homeCardsWithMeta = homeCards.map((card) => {
	if (!card.lastUpdated) return { card, lastUpdatedPill: null };
	const md = formatMarkdownDate(card.lastUpdated);
	const label =
		card.title === 'HomeLab Blog' ? md.label : formatListDate(md.isoDay);
	return { card, lastUpdatedPill: { isoDay: md.isoDay, label } };
});
---

<Layout
	title="kspice.dev"
>
	<main class="main">
		<h1 class="welcome-stack">
			<span class="welcome-line">Welcome to</span>
			<img
				class="home-hero-logo"
				src={heroLogoSrc}
				alt="kspice.dev"
				width="1000"
				height="1000"
				loading="eager"
				decoding="async"
			/>
		</h1>
		<ul class="cards home-cards">
			{
				homeCardsWithMeta.map(({ card, lastUpdatedPill }) => (
					<li>
						<a class="card" href={card.href}>
							<h2>{card.title}</h2>
							<p>{card.description}</p>
							{
								lastUpdatedPill ? (
									<p class="card-meta">
										<time class="card-meta-muted" datetime={lastUpdatedPill.isoDay}>
											Last updated {lastUpdatedPill.label}
										</time>
									</p>
								) : null
							}
						</a>
					</li>
				))
			}
		</ul>
	</main>
</Layout>

<style>
	.welcome-stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1rem;
		margin: 0 0 2.25rem;
	}

	.welcome-line {
		display: block;
		width: 100%;
	}

	.home-hero-logo {
		width: min(26rem, 100%);
		height: auto;
		display: block;
		border: none;
		border-radius: 12px;
	}

	.home-cards {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.home-cards > li {
		display: flex;
	}

	.home-cards .card {
		width: 100%;
		padding: 1rem 1.1rem;
	}

	@media (max-width: 34rem) {
		.home-cards {
			grid-template-columns: 1fr;
		}
	}
</style>
