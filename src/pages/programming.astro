---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Programming"
	description="Programming tutorials, projects, and notes on kspice.dev."
>
	<main class="main">
		<h1>Programming</h1>
		<p class="lede">
			Tutorials, side projects, and write-ups. Add posts here or link out to repos as you go.
		</p>
		<section class="section" aria-labelledby="soon-heading">
			<h2 id="soon-heading">Coming soon</h2>
			<p>
				This page is ready for content collections, markdown posts, or a simple list of project
				links—whatever you add next.
			</p>
		</section>
	</main>
</Layout>

<style>
	.main {
		max-width: 42rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
	}

	h1 {
		font-size: 1.75rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem;
	}

	.lede {
		margin: 0 0 2rem;
		color: #444;
		font-size: 1.0625rem;
	}

	.section h2 {
		font-size: 1rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
	}

	.section p {
		margin: 0;
		color: #555;
	}
</style>
