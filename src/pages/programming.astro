---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
import { sitePath } from '../utils/sitePath';
---

<Layout
	title="Programming Tutorials"
	description="Programming tutorials and lessons on kspice.dev."
>
	<main class="main">
		<h1>Programming Tutorials</h1>
		<p class="lede">
			Too often, developers research and create unique solutions that go undocumented and forgotten.
			The purpose of this page is to document and archive tutorials for future reference.
		</p>
		<section class="section" aria-labelledby="tutorials-heading">
			<h2 id="tutorials-heading">Tutorials</h2>
			<ul class="cards">
				<li>
					<a class="card" href={sitePath('/programming/aliases')}>
						<h3>Aliases</h3>
						<p>
							How to create and use aliases in bash, PowerShell, and Windows Command Prompt.
						</p>
					</a>
				</li>
			</ul>
		</section>
		<section class="section" aria-labelledby="contribute-heading">
			<h2 id="contribute-heading">Contribute</h2>
			<p>
				If you’d like to contribute to this, please{' '}
				<a href="mailto:kyledspicer@gmail.com">email me</a>
				{' '}
				and we can get it added!
			</p>
		</section>
	</main>
</Layout>
