---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
---

<Layout
	title="Programming Tutorials"
	description="Programming tutorials and lessons on kspice.dev."
>
	<main class="main">
		<h1>Programming Tutorials</h1>
		<p class="lede">
			Step-by-step tutorials and teaching notes. Add posts here or link out to repos and videos as
			you go.
		</p>
		<section class="section" aria-labelledby="soon-heading">
			<h2 id="soon-heading">Coming soon</h2>
			<p>
				Ready for tutorials as markdown posts, embedded videos, or a simple lesson list—whatever you
				add next.
			</p>
		</section>
	</main>
</Layout>
