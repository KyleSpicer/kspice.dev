---
import Layout from '../layouts/Layout.astro';
import '../styles/page-main.css';
---

<Layout
	title="Documented Projects"
	description="Documented programming and other projects on kspice.dev."
>
	<main class="main">
		<h1>Documented Projects</h1>
		<p class="lede">
			Write-ups, README-style docs, and deep dives for things you have built. Add case studies or
			link to repos as you go.
		</p>
		<section class="section" aria-labelledby="soon-heading">
			<h2 id="soon-heading">Coming soon</h2>
			<p>
				This page is ready for content collections, markdown posts, or a simple list of project
				links. Whatever you add next.
			</p>
		</section>
	</main>
</Layout>
