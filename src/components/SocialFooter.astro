				entries.map((entry) => (
					<li class="social-footer__cell">
						{entry.type === 'link' ? (
							<a
								class="social-pill"
								href={entry.href}
								title={
									entry.network === 'email'
										? 'Send email to kyledspicer@gmail.com'
										: undefined
								}
								{...(entry.network === 'email'
									? {}
									: { target: '_blank', rel: 'noopener noreferrer' })}
							>
								<span class="social-pill__icon" aria-hidden="true">
									{entry.network === 'facebook' && (
										<svg
											class="social-pill__svg"
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
