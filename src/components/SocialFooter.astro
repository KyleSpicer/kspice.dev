										</svg>
									)}
									{entry.network === 'email' && (
										<svg
											class="social-pill__svg"
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
										>
											<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
										</svg>
									)}
									{entry.network === 'github' && (
										<svg
											class="social-pill__svg"
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
										>
											<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
										</svg>
									)}
									{entry.network === 'gitlab' && (
										<svg
											class="social-pill__svg"
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
										>
											<path d="M22.65 14.39 12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51 1.22 3.78a.84.84 0 0 1-.3.94z" />
										</svg>
									)}
								</span>
								<span class="social-pill__label">{entry.short}</span>
							</a>
						) : (
							<button
								type="button"
								class="social-pill social-pill--copy"
								id="discord-copy-btn"
								data-clipboard={entry.handle}
								title={`Copy Discord username: ${entry.handle}`}
								aria-label={`Copy Discord username ${entry.handle}`}
							>
								<span class="social-pill__icon" aria-hidden="true">
									<svg
										class="social-pill__svg"
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="currentColor"
									>
										<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
									</svg>
								</span>
								<span class="social-pill__label">Discord</span>
							</button>
						)}
					</li>
				))
			}
		</ul>
		<p class="social-footer__status" id="discord-copy-status" role="status" aria-live="polite" aria-atomic="true" />
	</div>
</footer>

<script>
	function copyText(text: string): Promise<void> {
		if (navigator.clipboard?.writeText) {
			return navigator.clipboard.writeText(text);
		}
		return new Promise((resolve, reject) => {
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.setAttribute('readonly', '');
			ta.style.position = 'fixed';
			ta.style.left = '-9999px';
			document.body.appendChild(ta);
			ta.select();
			try {
				if (document.execCommand('copy')) resolve();
				else reject(new Error('execCommand failed'));
			} catch (e) {
				reject(e);
			} finally {
				document.body.removeChild(ta);
			}
		});
	}

	function setupDiscordCopy() {
		const btn = document.getElementById('discord-copy-btn');
		const status = document.getElementById('discord-copy-status');
		if (!btn || btn.dataset.copyBound === 'true') return;
		btn.dataset.copyBound = 'true';

		const text = btn.getAttribute('data-clipboard') || '';
		const baseLabel = btn.getAttribute('aria-label') || '';

		function setStatus(msg: string) {
			if (status) status.textContent = msg;
		}

		btn.addEventListener('click', async () => {
			try {
				await copyText(text);
				btn.classList.add('social-pill--copied');
				const okMsg = `${text} copied to clipboard`;
				btn.setAttribute('aria-label', okMsg);
				setStatus(okMsg);
				window.setTimeout(() => {
					btn.classList.remove('social-pill--copied');
					btn.setAttribute('aria-label', baseLabel);
					setStatus('');
				}, 2000);
			} catch {
				const errMsg = 'Could not copy; try selecting the username';
				btn.setAttribute('aria-label', errMsg);
				setStatus('Copy failed');
				window.setTimeout(() => {
					btn.setAttribute('aria-label', baseLabel);
					setStatus('');
				}, 2500);
			}
		});
	}

	setupDiscordCopy();
	document.addEventListener('astro:page-load', setupDiscordCopy);
</script>

<style>
	.social-footer {
		max-width: 46rem;
		margin: 0 auto;
		padding: 2rem 1rem 2.75rem;
		scroll-margin-top: 1.25rem;
	}

	.social-footer__panel {
		position: relative;
		padding: 1rem 0.85rem 1.15rem;
		border-radius: 14px;
		border: 1px solid var(--border);
		background: var(--bg-elevated);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--ink) 4%, transparent);
		overflow: hidden;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.social-footer__panel::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 2px;
		background: linear-gradient(90deg, var(--teal), var(--purple));
		opacity: 0.9;
	}

	.social-footer__head {
		text-align: center;
		margin-bottom: 0.65rem;
		padding-top: 0.15rem;
	}

	.social-footer__heading {
		margin: 0;
		font-size: 0.625rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--muted);
	}

	.social-footer__grid {
		list-style: none;
		margin: 0;
		padding: 0.2rem 0.15rem 0.1rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.45rem 0.4rem;
		align-items: stretch;
		justify-items: stretch;
	}

	.social-footer__cell {
		display: flex;
		min-width: 0;
	}

	.social-pill {
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.35rem;
		width: 100%;
		min-height: 2.35rem;
		padding: 0.35rem 0.4rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: var(--bg);
		color: var(--ink);
		text-decoration: none;
		font-size: 0.6875rem;
		font-weight: 600;
		line-height: 1.2;
		white-space: nowrap;
		transition:
			border-color 0.15s ease,
			background-color 0.15s ease,
			box-shadow 0.15s ease,
			transform 0.15s ease;
	}

	a.social-pill:hover {
		border-color: var(--teal);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--purple) 12%, transparent);
		transform: translateY(-1px);
	}

	a.social-pill:focus-visible,
	button.social-pill:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: 2px;
	}

	button.social-pill {
		font: inherit;
		cursor: pointer;
		margin: 0;
		-webkit-tap-highlight-color: transparent;
		touch-action: manipulation;
		appearance: none;
	}

	.social-pill--copy:hover {
		border-color: var(--teal);
		box-shadow: 0 2px 10px color-mix(in srgb, var(--purple) 12%, transparent);
		transform: translateY(-1px);
	}

	.social-pill--copy:hover .social-pill__icon {
		background: color-mix(in srgb, var(--teal) 18%, var(--bg));
		color: var(--teal-dark);
	}

	.social-pill--copied {
		border-color: var(--teal) !important;
		box-shadow: 0 0 0 2px var(--teal-soft);
	}

	.social-pill__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.15rem;
		height: 2.15rem;
		border-radius: 50%;
		background: color-mix(in srgb, var(--purple) 14%, var(--bg));
		color: var(--purple-dark);
		flex-shrink: 0;
		transition: background-color 0.15s ease, color 0.15s ease;
	}

	a.social-pill:hover .social-pill__icon {
		background: color-mix(in srgb, var(--teal) 18%, var(--bg));
		color: var(--teal-dark);
	}

	.social-pill__svg {
		width: 1.2rem;
		height: 1.2rem;
		display: block;
	}

	.social-pill__label {
		flex: 1 1 0%;
		padding-right: 0.1rem;
		min-width: 0;
		text-align: left;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.social-footer__status {
		margin: 0.65rem 0 0;
		min-height: 1.35em;
		text-align: center;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--teal-dark);
		transition: opacity 0.2s ease;
	}

	.social-footer__status:empty {
		min-height: 0;
		margin-top: 0;
	}

	@media (min-width: 480px) {
		.social-footer__grid {
			gap: 0.5rem 0.45rem;
		}
	}

	@media (min-width: 640px) {
		.social-footer__panel {
			padding: 1.1rem 1.1rem 1.2rem;
		}
	}
</style>
