type SocialEntry =
	| { type: 'link'; network: Network; href: string; short: string }
	| { type: 'discord'; handle: string };

const entries: SocialEntry[] = [
	{
		type: 'link',
		network: 'facebook',
		href: 'https://www.facebook.com/NotoriousKID7/',
		short: 'FB · Personal',
	},
	{
		type: 'link',
		network: 'facebook',
		href: 'https://www.facebook.com/SpicerWoodworking/',
		short: 'FB · Woodworking',
	},
	{
		type: 'link',
		network: 'linkedin',
		href: 'https://www.linkedin.com/in/kyle-spicer-741931aa/',
		short: 'LinkedIn',
	},
	{
		type: 'link',
		network: 'instagram',
		href: 'https://www.instagram.com/kyle_d_spicer/',
		short: 'Instagram',
	},
	{
		type: 'link',
		network: 'x',
		href: 'https://x.com/KyleDSpicer',
		short: 'X',
	},
	{
		type: 'link',
		network: 'email',
		href: 'mailto:kyledspicer@gmail.com',
		short: 'Email',
	},
	{ type: 'discord', handle: 'kylespicer' },
	{
		type: 'link',
		network: 'github',
		href: 'https://github.com/KyleSpicer',
		short: 'GitHub',
	},
	{
		type: 'link',
		network: 'gitlab',
		href: 'https://gitlab.com/kyledspicer',
		short: 'GitLab',
	},
