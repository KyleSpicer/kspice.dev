---
import { formatListDate } from '../utils/formatListDate';
import { formatMarkdownDate } from '../utils/formatMarkdownDate';

export interface RecentPostedItem {
	title: string;
	href: string;
	at: Date;
	/** Short category (e.g. HomeLab). */
	badge: string;
}

interface Props {
	items: RecentPostedItem[];
}

const { items } = Astro.props;
---

{
	items.length > 0 ? (
		<section class="recent-posted" aria-label="Recently posted on this site">
			<details class="recent-posted__details">
				<summary class="recent-posted__summary">
					<span class="recent-posted__summary-text">Recently posted</span>
					<span class="recent-posted__chevron" aria-hidden="true">
						<svg
							class="recent-posted__chevron-svg"
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="m6 9 6 6 6-6" />
						</svg>
					</span>
				</summary>
				<div
					class="recent-posted__scroll"
					tabindex="0"
					role="region"
					aria-label={`Scroll through ${items.length} recent items`}
				>
					<ol class="recent-posted__list">
						{items.map((item) => {
							const { isoDay } = formatMarkdownDate(item.at);
							return (
								<li class="recent-posted__item">
									<a class="recent-posted__link" href={item.href}>
										<span class="recent-posted__title">{item.title}</span>
										<span class="recent-posted__meta">
											{item.badge} · <time datetime={isoDay}>{formatListDate(isoDay)}</time>
										</span>
									</a>
								</li>
							);
						})}
					</ol>
				</div>
			</details>
		</section>
	) : null
}

<style>
	.recent-posted {
		margin: 0 0 1.75rem;
	}

	.recent-posted__details {
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--bg-elevated);
		overflow: hidden;
		box-shadow: 0 2px 10px color-mix(in srgb, var(--ink) 4%, transparent);
	}

	.recent-posted__details::before {
		content: '';
		display: block;
		height: 2px;
		background: linear-gradient(90deg, var(--teal), var(--purple));
		opacity: 0.85;
	}

	.recent-posted__summary {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		padding: 0.75rem 1rem;
		cursor: pointer;
		font-weight: 600;
		font-size: 0.8125rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--muted);
		user-select: none;
		transition:
			color 0.15s ease,
			background-color 0.15s ease;
	}

	.recent-posted__summary::-webkit-details-marker {
		display: none;
	}

	.recent-posted__summary:hover {
		color: var(--teal-dark);
		background: color-mix(in srgb, var(--teal) 6%, var(--bg));
	}

	.recent-posted__summary:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: -2px;
		border-radius: 0;
	}

	.recent-posted__details[open] .recent-posted__summary {
		border-bottom: 1px solid var(--border);
	}

	.recent-posted__summary-text {
		flex: 1;
		min-width: 0;
	}

	.recent-posted__chevron {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.85rem;
		height: 1.85rem;
		border-radius: 8px;
		background: color-mix(in srgb, var(--purple) 12%, var(--bg));
		color: var(--purple-dark);
		flex-shrink: 0;
		transition:
			transform 0.2s ease,
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.recent-posted__details[open] .recent-posted__chevron {
		transform: rotate(180deg);
		background: color-mix(in srgb, var(--teal) 14%, var(--bg));
		color: var(--teal-dark);
	}

	.recent-posted__chevron-svg {
		width: 1rem;
		height: 1rem;
		display: block;
	}

	/* ~10 compact rows visible; remainder scrolls (matches up to 50 items fed from the homepage). */
	.recent-posted__scroll {
		--recent-visible-rows: 10;
		--recent-row-estimate: 2.72rem;
		max-height: calc(var(--recent-visible-rows) * var(--recent-row-estimate));
		min-height: 0;
		overflow-x: hidden;
		overflow-y: auto;
		overscroll-behavior: contain;
		scrollbar-gutter: stable;
		scrollbar-width: thin;
		scrollbar-color: color-mix(in srgb, var(--muted) 55%, transparent) var(--bg-elevated);
		-webkit-overflow-scrolling: touch;
		outline: none;
	}

	.recent-posted__scroll:focus-visible {
		box-shadow: inset 0 0 0 2px var(--purple-soft);
	}

	.recent-posted__scroll::-webkit-scrollbar {
		width: 8px;
	}

	.recent-posted__scroll::-webkit-scrollbar-track {
		background: var(--bg-elevated);
	}

	.recent-posted__scroll::-webkit-scrollbar-thumb {
		background-color: color-mix(in srgb, var(--muted) 45%, transparent);
		border-radius: 8px;
		border: 2px solid var(--bg-elevated);
	}

	.recent-posted__list {
		margin: 0;
		padding: 0.35rem 0 0.65rem;
		list-style-type: decimal;
		list-style-position: outside;
		padding-inline-start: 2.85rem;
	}

	.recent-posted__item {
		padding-right: 0.35rem;
		border-bottom: 1px solid color-mix(in srgb, var(--border) 88%, transparent);
	}

	.recent-posted__item:last-child {
		border-bottom: none;
	}

	.recent-posted__link {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.25rem;
		padding: 0.65rem 0.25rem 0.7rem 0.85rem;
		margin-inline-start: -0.5rem;
		text-decoration: none;
		color: var(--ink);
		transition:
			background-color 0.12s ease,
			color 0.12s ease;
		min-width: 0;
	}

	.recent-posted__link:hover {
		background: color-mix(in srgb, var(--purple) 6%, var(--bg));
	}

	.recent-posted__link:focus-visible {
		outline: 2px solid var(--purple);
		outline-offset: -4px;
	}

	.recent-posted__title {
		font-weight: 600;
		font-size: 0.9375rem;
		line-height: 1.3;
	}

	.recent-posted__meta {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--muted-dim);
		opacity: 0.95;
	}

	.recent-posted__meta time {
		white-space: nowrap;
	}
</style>
